#!name=Apple WLOC 定位修改 (snapshot - raw backup)
#!desc=Snapshot module that points to the time-capsule raw URLs (backup). Use if upstream is unavailable.
#!icon=https://raw.githubusercontent.com/berths7midland/wloc-time-capsule/refs/heads/main/wloc.jpg
#!author=berths7midland
#!homepage=https://github.com/berths7midland/wloc-time-capsule
#!openUrl=https://wolc.leclub.cyou/

[Argument]
longitude = input, "113.94114", tag=经度(在线选点优先)
latitude = input, "22.544577", tag=纬度(在线选点优先)
accuracy = input, "25", tag=精度(米)
logLevel = select, "info", "off", "error", "warn", "debug", "all", tag=日志级别

[Script]
http-response ^https?:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc script-path=https://raw.githubusercontent.com/berths7midland/wloc-time-capsule/refs/heads/main/dist/wloc.js, requires-body=true, binary-body-mode=true, timeout=30, tag=Apple WLOC, argument=[{longitude},{latitude},{accuracy},{logLevel}]
http-request ^https?:\/\/gs-loc(-cn)?\.apple\.com\/wloc-settings\/save script-path=https://raw.githubusercontent.com/berths7midland/wloc-time-capsule/refs/heads/main/dist/wloc-settings.js, timeout=10, tag=WLOC Settings

[MITM]
hostname = gs-loc.apple.com, gs-loc-cn.apple.com
