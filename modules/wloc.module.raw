#!name=Apple WLOC 定位修改 (snapshot - raw backup)
#!desc=Snapshot module that points to the time-capsule raw URLs (backup). Use if upstream is unavailable.
#!author=berths7midland
#!homepage=https://github.com/berths7midland/wloc-time-capsule
#!icon=https://raw.githubusercontent.com/berths7midland/wloc-time-capsule/refs/heads/main/wloc.jpg
#!category=Tools

[Script]
Apple WLOC = type=http-response,pattern=^https?:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc,requires-body=1,binary-body-mode=1,max-size=0,timeout=30,script-path=https://raw.githubusercontent.com/berths7midland/wloc-time-capsule/refs/heads/main/dist/wloc.js,argument=longitude=113.94114&latitude=22.544577&accuracy=25&logLevel=info
WLOC Settings = type=http-request,pattern=^https?:\/\/gs-loc(-cn)?\.apple\.com\/wloc-settings\/save,requires-body=0,max-size=0,timeout=10,script-path=https://raw.githubusercontent.com/berths7midland/wloc-time-capsule/refs/heads/main/dist/wloc-settings.js

[MITM]
hostname = %APPEND% gs-loc.apple.com, gs-loc-cn.apple.com
