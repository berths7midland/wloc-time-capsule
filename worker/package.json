{
  "type": "module",
  "scripts": {
    "audit:links": "node scripts/audit-links.mjs",
    "clean:check": "node scripts/git-clean.mjs",
    "hashes:generate": "node scripts/hashes.mjs generate",
    "hashes:verify": "node scripts/hashes.mjs verify",
    "test": "node --test src/parse.test.mjs src/index.test.mjs",
    "pages:prepare": "node scripts/prepare-pages.mjs",
    "prepages:dev": "npm run pages:prepare",
    "verify": "npm run clean:check && npm run pages:prepare && npm run clean:check && npm test && npm run audit:links && npm run hashes:verify",
    "dev": "wrangler dev --config=wrangler.worker.jsonc",
    "deploy:worker": "wrangler deploy --minify --config=wrangler.worker.jsonc",
    "deploy:pages": "wrangler pages deploy dist --project-name=wloc-time-capsule --branch=main",
    "deploy": "npm run verify && npm run deploy:worker",
    "deploy:all": "npm run verify && npm run deploy:worker && npm run deploy:pages",
    "pages:dev": "wrangler pages dev dist --port 8787 --compatibility-date=2024-01-01 --compatibility-flag=nodejs_compat",
    "pages:deploy": "npm run verify && npm run deploy:pages"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "wrangler": "4.110.0"
  }
}
